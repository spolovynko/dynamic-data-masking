DDM_QUEUE_RESULT_BACKEND=redis://localhost:6379/1
DDM_QUEUE_NAME=ddm
DDM_CELERY_TASK_ALWAYS_EAGER=false
DDM_WORKER_POOL=solo
DDM_WORKER_LOG_LEVEL=INFO
