DDM_SERVICE_NAME=dynamic-data-masking
DDM_APP_NAME=Dynamic Data Masking
DDM_APP_VERSION=0.1.0
DDM_ENVIRONMENT=local
DDM_API_HOST=127.0.0.1
DDM_API_PORT=8000
DDM_API_RELOAD=true
DDM_API_PREFIX=/api
DDM_DATA_ROOT=data
DDM_MAX_UPLOAD_BYTES=26214400
DDM_DATABASE_URL=
DDM_OBJECT_STORE_BACKEND=local
DDM_OBJECT_STORE_ROOT=
DDM_QUEUE_BROKER_URL=redis://localhost:6379/0
DDM_QUEUE_RESULT_BACKEND=redis://localhost:6379/1
DDM_QUEUE_NAME=ddm
DDM_CELERY_TASK_ALWAYS_EAGER=false
DDM_WORKER_POOL=solo
DDM_WORKER_LOG_LEVEL=INFO
DDM_WORKER_METRICS_PORT=9101
DDM_OCR_ENABLED=true
DDM_OCR_LANGUAGE=eng
DDM_OCR_DPI=200
DDM_OCR_MIN_NATIVE_TOKENS=1
DDM_PRESIDIO_ENABLED=false
DDM_PRESIDIO_ENTITIES=PERSON
DDM_LLM_ENABLED=false
DDM_LLM_PROVIDER=ollama
DDM_OLLAMA_BASE_URL=http://127.0.0.1:11434
DDM_OLLAMA_MODEL=qwen2.5:3b
DDM_LLM_TEMPERATURE=0
DDM_LLM_MAX_CONTEXT_CHARS=1200
DDM_LLM_TIMEOUT_SECONDS=120
DDM_LOG_LEVEL=INFO
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
