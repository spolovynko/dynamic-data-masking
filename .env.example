DDM_APP_VERSION=0.1.0
DDM_ENVIRONMENT=local
DDM_API_HOST=127.0.0.1
DDM_API_PORT=8000
DDM_API_RELOAD=true
DDM_API_PREFIX=/api
DDM_DATA_ROOT=data
DDM_MAX_UPLOAD_BYTES=26214400
